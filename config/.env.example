# ========================================
# CONFIGURATION DE LA BASE DE DONNÉES
# ========================================
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=bantu_consulting

# ========================================
# CONFIGURATION SMTP
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@bantu-consulting.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Bantu Consulting

# ========================================
# CONFIGURATION DU SITE
# ========================================
SITE_NAME=Bantu Consulting
SITE_URL=https://bantu-consulting.com
ADMIN_EMAIL=admin@bantu-consulting.com

# ========================================
# CLÉS DE SÉCURITÉ
# ========================================
SECRET_KEY=change_this_to_random_string_32_characters
API_KEY=your_api_key_here
INSTALLATION_TOKEN=change_me_in_production

# ========================================
# ENVIRONNEMENT
# ========================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=warning

# ========================================
# STOCKAGE ET UPLOADS
# ========================================
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=/uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf

# ========================================
# SESSIONS
# ========================================
SESSION_TIMEOUT=1800
SESSION_NAME=BANTU_SESSION

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_TIMEOUT=300
